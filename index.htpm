<!DOCTYPE html>
<html>
<head>
  <title>Meu Site</title>

  <style>
    body {
      font-family: arial;
    }

    .menu {
      background-color: #3498db;
      padding: 10px;
    }

    .menu a {
      color: white;
      margin-right: 15px;
      text-decoration: none;
      font-weight: bold;
    }

    .dropdown {
      display: inline-block;
      position: relative;
    }

    .dropdown-content {
      display: none;
      position: absolute;
      background-color: white;
      min-width: 150px;
    }

    .dropdown-content a {
      display: block;
      color: black;
      padding: 10px;
      text-decoration: none;
    }

    .dropdown:hover .dropdown-content {
      display: block;
    }

    /* SUBMENU (Matific) */
    .dropdown-sub {
      position: relative;
    }

    .dropdown-sub-content {
      display: none;
      position: absolute;
      left: 150px;
      top: 0;
      background-color: white;
      min-width: 180px;
    }

    .dropdown-sub-content a {
      display: block;
      padding: 10px;
      color: black;
    }

    .dropdown-sub:hover .dropdown-sub-content {
      display: block;
    }
  </style>
</head>

<body>

<div class="menu">
  <a href="https://sites.google.com/escola.pr.gov.br/coordenaodeeducaodigital/in%C3%ADcio" target="_blank">Início</a>
  <a href="contato.html">Contato</a>

  <div class="dropdown">
    <a href="#">Matérias ▼</a>

    <div class="dropdown-content">

      <!-- MATIFIC (não clica direto) -->
      <div class="dropdown-sub">
        <a href="#">Matific ▶</a>

        <div class="dropdown-sub-content">
          <a href="https://www.matific.com" target="_blank">Matemática 6º ano</a>
          <a href="https://www.matific.com" target="_blank">Matemática 7º ano</a>
          <a href="https://www.matific.com" target="_blank">6º ano Recomposição</a>
        </div>
      </div>

      <!-- KHAN -->
      <div class="dropdown-sub">
  <a href="#">Khan Academy ▶</a>

  <div class="dropdown-sub-content">
    <a href="https://www.khanacademy.org" target="_blank">Matemática 9º ano</a>
    <a href="https://www.khanacademy.org" target="_blank">Matemática 9º ano Recomposição</a>
    <a href="https://www.khanacademy.org" target="_blank">Matemática 1º ano Resolução de Problemas</a>
    <a href="https://www.khanacademy.org" target="_blank">Matemática 3º ano Recomposição</a>
    <a href="https://www.khanacademy.org" target="_blank">Khanmigo para Professores</a>
  </div>
</div>

    </div>
  </div>
</div>

<h1>Bem-vindo ao meu site!</h1>
